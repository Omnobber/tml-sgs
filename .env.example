# Server
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://sgs:sgs_password@localhost:5432/sgs_cms
JWT_ACCESS_SECRET=replace_with_secure_access_secret
JWT_REFRESH_SECRET=replace_with_secure_refresh_secret
ACCESS_TOKEN_EXPIRY=8h
REFRESH_TOKEN_EXPIRY_DAYS=7
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
ALLOW_DEMO_AUTH_FALLBACK=true

# Client
VITE_API_BASE_URL=http://localhost:4000/api
